  "description": {
    "en-US": "Travel phrases for Portugal with audio, built for tram rides, train travel, hotel check-ins, cafe counters, and everyday payment or direction questions.",
    "zh-CN": "葡萄牙旅行短语卡，围绕电车、火车、酒店入住、咖啡馆柜台以及支付和问路等高频场景整理。"
  },
  "intro": {
    "en-US": "Built for Portugal trips where trams, train stations, apartment check-ins, cafe counters, and coastal day trips all come up fast. These cards help when you need short Portuguese for tram stops, Multibanco payment questions, or bakery and cafe orders that go by quickly.",
    "zh-CN": "这套葡萄牙短语适合那种电车、火车站、公寓入住、咖啡馆柜台和海边一日游会快速切换的旅行节奏。遇到要确认电车站、Multibanco 支付，或者在面包店和咖啡馆里快速点单时，短语卡会很实用。"
  },
  "teaser": {
    "en-US": "Built for Portugal tram rides, Multibanco payments, cafe counters, train travel, and hotel or apartment arrivals.",
    "zh-CN": "适合葡萄牙的电车、Multibanco、咖啡馆柜台、火车以及酒店或公寓入住沟通。"
  },
  "travelTips": {
    "en-US": [
      "Keep transport phrases ready for tram stops, train platforms, and station questions because route names can be easy to miss.",
      "Payment phrases help with Multibanco, cards, and cash questions, especially in cafes and smaller local shops.",
      "Cafe counters move quickly, so short Portuguese is useful for espresso orders, takeaway, and asking what pastries are still available."
    ],
    "zh-CN": [
      "电车站、火车站站台和换乘询问很常用，交通短语最好提前准备好。",
      "支付类短语在葡萄牙也很实用，尤其是确认 Multibanco、刷卡还是现金时。",
      "咖啡馆柜台节奏很快，想点 espresso、外带，或者问今天还有什么点心时，简短葡语会很好用。"
    ]
  },
  "highlights": {
    "en-US": [
      "Trams, Multibanco, and cafe counters",
      "Train travel, pastries, and takeaway",
      "Hotels, apartments, and coastal day trips"
    ],
    "zh-CN": [
      "电车、Multibanco 与咖啡馆柜台",
      "火车、点心与外带需求",
      "酒店、公寓与海边一日游"
    ]
  },
