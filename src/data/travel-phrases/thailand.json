    "vietnam"
  ],
  "faq": [
    {
      "question": {
        "en-US": "Which phrase section matters most on the first day in Thailand?",
        "zh-CN": "刚到泰国的第一天，最该先准备哪一组短语？"
      },
      "answer": {
        "en-US": "Start with transport, hotel, and dining. That covers airport transfers, BTS or Grab questions, check-in, and the first round of street-food or food-court orders.",
        "zh-CN": "建议先看交通、酒店和餐饮三组，基本就能覆盖机场接驳、BTS 或 Grab、入住办理，以及第一顿街边或美食广场点餐。"
      }
    },
    {
      "question": {
        "en-US": "Do I need fluent Thai to use these cards in Thailand?",
        "zh-CN": "在泰国使用这些短语卡，需要会说很流利的泰语吗？"
      },
      "answer": {
        "en-US": "No. A short phrase, the on-screen card, and audio for key moments are usually enough for transport staff, hotel teams, and food stalls.",
        "zh-CN": "不用。会几句简短表达，加上直接展示屏幕上的短语卡，必要时再放音频，通常就足够应对交通人员、酒店前台和餐饮摊位。"
      }
    }
  ]
}
