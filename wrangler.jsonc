{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "route-crate",
  "compatibility_date": "2026-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "routes": [
    {
      "pattern": "routecrate.com",
      "custom_domain": true
    },
    {
      "pattern": "www.routecrate.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "split-bill",
      "database_id": "37c57e0d-96f1-4181-acdc-98c9b35a5ebd"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHRASE_AUDIO",
      "bucket_name": "route-crate-phrase-audio"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "APP_KV",
      "id": "742b0c83b37742e0b273029d096b0710",
      "preview_id": "8b686cb8f76b4502959683ac5c0f4e48"
    },
    {
      "binding": "RATES_KV",
      "id": "a9fed0b89c584406a7692849359a2ce5"
    }
  ],
  "vars": {
    "APP_NAME": "Route Crate",
    "FX_API_BASE_URL": "https://api.frankfurter.app",
    "GA_MEASUREMENT_ID": "G-41BFL5B41F",
    "GOOGLE_ANALYTICS_ID": "G-41BFL5B41F",
    "UMAMI_WEBSITE_ID": "a9367edf-7fe2-46c4-ba26-8dd04cbd66ff",
    "UMAMI_SCRIPT_URL": "https://cloud.umami.is/script.js"
  }
}
